{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "description": "Group NPM packages together.",
    "packageRules": [
        {
            "matchCategories": [
                "node",
                "npm"
            ],
            "matchUpdateTypes": [
                "major",
                "minor",
                "patch",
                "rollback",
                "replacement"
            ],
            "groupName": "Node Packages",
            "groupSlug": "node"
        }
    ]
}